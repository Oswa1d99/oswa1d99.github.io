---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagChip from '../../components/TagChip.astro';
import { getCollection } from 'astro:content';
import { resolveAllColors } from '../../lib/color-resolution';
import { estimateReadingTime } from '../../lib/reading-time';
import { formatDate } from '../../lib/format-date';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.add(tag);
    }
  }
  return [...tags].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const colorMap = resolveAllColors(allPosts);
const posts = allPosts
  .filter(p => p.data.tags.includes(tag!))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`Tag: ${tag}`} lang="ko">
  <div class="content-wrap page-content">
    <h1 class="post-title" style="margin-bottom: 8px;">
      <TagChip tag={tag!} colorMap={colorMap} linked={false} />
    </h1>
    <p class="page-subtitle">
      {posts.length} post{posts.length !== 1 ? 's' : ''}
    </p>
    <ul class="post-list">
      {posts.map(post => (
        <li class="post-list-item">
          <a href={`/posts/${post.id}`} class="post-list-title">{post.data.title}</a>
          <p class="post-list-description">{post.data.description}</p>
          <div class="post-list-meta">
            <span class="category-label">{post.data.category}</span>
            <span class="dot-sep">·</span>
            <span>{formatDate(post.data.pubDate)}</span>
            <span class="dot-sep">·</span>
            <span>{estimateReadingTime(post.body || '', post.data.lang)}min</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
