---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesBadge from '../../components/SeriesBadge.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getCollection } from 'astro:content';
import { resolveAllColors } from '../../lib/color-resolution';
import { groupBySeries } from '../../lib/series-utils';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const colorMap = resolveAllColors(posts);
const seriesMap = groupBySeries(posts);
const sortedSeries = [...seriesMap.entries()].sort((a, b) => b[1].posts.length - a[1].posts.length);
---

<BaseLayout title="Series" lang="ko">
  <div class="content-wrap page-content">
    <h1 class="post-title" style="margin-bottom: 32px;">series</h1>
    {sortedSeries.length === 0 ? (
      <EmptyState message="No series yet." />
    ) : (
      <ul class="series-index">
        {sortedSeries.map(([name, info]) => {
          const firstPost = info.posts[0];
          return (
            <li class="series-index-item">
              <SeriesBadge series={name} colorMap={colorMap} />
              <div class="series-index-count">{info.posts.length} post{info.posts.length !== 1 ? 's' : ''}</div>
              {firstPost && (
                <div style="font-family: var(--font-display); font-size: 0.72rem; color: var(--text-tertiary); margin-top: 2px;">
                  {firstPost.data.title}
                </div>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </div>
</BaseLayout>
