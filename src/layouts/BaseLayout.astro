---
import { siteConfig } from '../data/site-config';
import ThemeToggle from '../components/ThemeToggle.astro';
import CustomSearch from '../components/CustomSearch.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'ko' } = Astro.props;
const pageTitle = title ? `${title} — ${siteConfig.title}` : `${siteConfig.title}.dev`;
const pageDescription = description || siteConfig.description;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <ClientRouter />
  <meta name="description" content={pageDescription} />
  <meta name="author" content={siteConfig.author} />
  <link rel="canonical" href={`${siteConfig.siteUrl}${Astro.url.pathname}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Gowun+Dodum&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">

  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={`${siteConfig.siteUrl}${Astro.url.pathname}`} />
  <meta property="og:image" content={`${siteConfig.siteUrl}/og-image.svg`} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={`${siteConfig.siteUrl}/og-image.svg`} />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title}.dev RSS Feed`} href={`${siteConfig.siteUrl}/rss.xml`} />

  {siteConfig.umami.enabled && siteConfig.umami.src && siteConfig.umami.websiteId && (
    <script async src={siteConfig.umami.src} data-website-id={siteConfig.umami.websiteId}></script>
  )}

  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
      
      if (sessionStorage.getItem('logo-animated')) {
        document.documentElement.classList.add('has-animated');
      }

      document.addEventListener('astro:before-swap', function(e) {
        if (sessionStorage.getItem('logo-animated')) {
          e.newDocument.documentElement.classList.add('has-animated');
        }
      });
    })();
  </script>

</head>
<body>
  <nav class="site-nav">
    <div class="site-nav-inner">
      <a href="/" class="site-nav-logo">{siteConfig.title}</a>
      <div class="nav-actions">
        <ul class="site-nav-links">
          <li><a href="/posts">posts</a></li>
          <li><a href="/about">about</a></li>
        </ul>
        <span id="search-toggle" class="nav-icon" role="button" tabindex="0" aria-label="Search" style="cursor: pointer;">⌕</span>
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <CustomSearch />

  <main>
    <slot />
  </main>
</body>
</html>
